# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real tokens.

# Figma source (required for /compare and AI vision workflows)
FIGMA_FILE_URL=https://www.figma.com/design/<fileKey>/untitled?node-id=<nodeId>
FIGMA_NODE_ID=<nodeId>
FIGMA_PAT=figd_...

# AI provider key for token re-extraction (optional)
# VITE_GEMINI_API_KEY=