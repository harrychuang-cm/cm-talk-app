{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeatureManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "productName",
    "features"
  ],
  "properties": {
    "schemaVersion": {
      "type": "number"
    },
    "productName": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "priority",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "userStories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptanceCriteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "affectedScreens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "flows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "changeHistory": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}